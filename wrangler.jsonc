{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "e-phram-store",
	"main": "backend/src/index.ts",
	"compatibility_date": "2026-04-12",
	"observability": {
		"enabled": true
	},
	"assets": {
		"directory": "dist",
		"not_found_handling": "single-page-application"
	},
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "e-pharm-d1",
			"database_id": "d621546c-de06-4bca-9eb8-3b26ebdec9f3"
		},
		{
			"binding": "my_database",
			"database_name": "my-database",
			"database_id": "7953d7e7-4180-4ee6-8059-c757ffb82cbb"
		},
		{
			"binding": "e_phramcy",
			"database_name": "epharm-db",
			"database_id": "7b957beb-2ee1-4080-a205-8b44020966aa",
			"remote": true
		},
		{
			"binding": "Y",
			"database_name": "e_pharm_d1",
			"database_id": "d621546c-de06-4bca-9eb8-3b26ebdec9f3",
			"remote": true
		}
	],
	"kv_namespaces": [
		{
			"binding": "EPHRAM_KV",
			"id": "e08d75a05eca4a1e8e29b17f7e8e38d2",
			"remote": true
		},
		{
			"binding": "STORE_KV",
			"id": "e08d75a05eca4a1e8e29b17f7e8e38d2"
		}
	]
}